{
  "name": "xliff-translator",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @xliff-translator/server\" \"npm run dev -w @xliff-translator/web\"",
    "build": "npm run build -w @xliff-translator/core && npm run build -w @xliff-translator/server && npm run build -w @xliff-translator/web",
    "test": "npm run test -w @xliff-translator/core",
    "start": "npm run start -w @xliff-translator/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  }
}
